#!/usr/bin/env bash
# extract-frames <video> [count] [out-dir]
# Pulls N evenly-spaced frames from a video as JPGs (quality 4 — small but
# legible). Prints one absolute frame path per line on stdout.
#
# Default count = 8 frames, which fits in a model's image context without
# wasting tokens on near-duplicates and still tells the visual story of a
# typical 30s–3min clip.
#
# Exit codes (see docs/exit-codes.md):
#   0 success · 1 general · 2 missing-dep · 64 usage error

set -uo pipefail

# Resolve symlinks so $ROOT_DIR points at the real install dir, not ~/.local.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  [[ $SELF != /* ]] && SELF="$SELF_DIR/$SELF"
done
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(cd "$SELF_DIR/.." && pwd)"
# shellcheck source=../lib/version.sh
source "$ROOT_DIR/lib/version.sh"

VIDEO=""
COUNT="8"
OUTDIR_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -V|--version)
      echo "$WATCH_CLI_VERSION_STRING"
      exit 0
      ;;
    *)
      if [[ -z "$VIDEO" ]]; then
        VIDEO="$1"
      elif [[ "$COUNT" == "8" ]]; then
        COUNT="$1"
      elif [[ -z "$OUTDIR_ARG" ]]; then
        OUTDIR_ARG="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$VIDEO" ]]; then
  echo "usage: extract-frames <video> [count] [out-dir] tag=usage-error" >&2
  exit 64
fi

if [[ ! -f "$VIDEO" ]]; then
  echo "[extract-frames] error: file not found: $VIDEO tag=usage-error" >&2
  exit 64
fi

if ! [[ "$COUNT" =~ ^[0-9]+$ ]] || (( COUNT < 1 )); then
  echo "[extract-frames] error: count must be positive integer, got: $COUNT tag=usage-error" >&2
  exit 64
fi

for dep in ffmpeg ffprobe python3; do
  if ! command -v "$dep" >/dev/null 2>&1; then
    echo "[extract-frames] error: $dep not found on PATH tag=missing-dep:$dep" >&2
    exit 2
  fi
done

# Output dir: explicit arg > /tmp/frames_<basename>_<hash>.
if [[ -n "$OUTDIR_ARG" ]]; then
  OUTDIR="$OUTDIR_ARG"
else
  HASH="$(echo -n "$VIDEO" | shasum | cut -c1-8)"
  BASE="$(basename "$VIDEO" .mp4)"
  OUTDIR="/tmp/frames_${BASE}_${HASH}"
fi
mkdir -p "$OUTDIR"

# Total duration in seconds (float).
DUR="$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$VIDEO" 2>/dev/null || echo 0)"
if [[ "$DUR" == "0" || -z "$DUR" ]]; then
  echo "[extract-frames] error: could not read duration from $VIDEO" >&2
  exit 1
fi

# Evenly-spaced timestamps: ((i+1)/(count+1)) * duration. Skips first/last
# frame (often black or credits).
python3 - "$DUR" "$COUNT" <<'PY' > "$OUTDIR/.timestamps"
import sys
dur = float(sys.argv[1])
n = int(sys.argv[2])
for i in range(1, n + 1):
    t = (i / (n + 1)) * dur
    print(f"{t:.3f}")
PY

i=1
emitted=0
while IFS= read -r ts; do
  out="$OUTDIR/frame_$(printf "%02d" "$i").jpg"
  if ffmpeg -hide_banner -loglevel error -y -ss "$ts" -i "$VIDEO" -frames:v 1 -q:v 4 "$out" >&2 2>&1; then
    if [[ -s "$out" ]]; then
      echo "$out"
      emitted=$((emitted + 1))
    fi
  fi
  i=$((i + 1))
done < "$OUTDIR/.timestamps"

rm -f "$OUTDIR/.timestamps"

if (( emitted == 0 )); then
  echo "[extract-frames] error: no frames extracted from $VIDEO" >&2
  exit 1
fi
