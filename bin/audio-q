#!/usr/bin/env bash
# audio-q <audio-or-video> "<question>" [--model <model-name>]
# Asks a multimodal LLM a question about an audio/video file. Goes beyond
# pure speech-to-text: hears tone, music, ambient SFX, speaker emotion,
# language, pacing — the full audio scene.
#
# Routing:
#   - Kyma mode (KYMA_API_KEY set): POST api.kymaapi.com/v1/audio/understand
#     Get a Kyma key at https://kymaapi.com.
#   - Direct mode (GOOGLE_AI_KEY set): POST Gemini API directly (BYO).
#
# Model selection (priority order):
#   1. --model <model-name> flag (explicit override for this call)
#   2. WATCH_AUDIO_MODEL env var (default model for audio-q)
#   3. Built-in default: gemini-2.5-flash (for direct mode)
#
# Exit codes (see docs/exit-codes.md):
#   0 success · 1 general · 2 missing-dep · 4 transcribe fail · 64 usage error

set -uo pipefail

# Resolve symlinks so ROOT_DIR points at the real install dir, not ~/.local.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  [[ $SELF != /* ]] && SELF="$SELF_DIR/$SELF"
done
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(cd "$SELF_DIR/.." && pwd)"
# shellcheck source=../lib/env.sh
source "$ROOT_DIR/lib/env.sh"

INPUT=""
QUESTION=""
MODEL=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -V|--version)
      echo "$WATCH_CLI_VERSION_STRING"
      exit 0
      ;;
    --model)
      if [[ -z "${2:-}" ]]; then
        echo '[audio-q] error: --model requires a value tag=usage-error' >&2
        exit 64
      fi
      MODEL="$2"
      shift 2
      ;;
    *)
      if [[ -z "$INPUT" ]]; then
        INPUT="$1"
      elif [[ -z "$QUESTION" ]]; then
        QUESTION="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$INPUT" || -z "$QUESTION" ]]; then
  echo 'usage: audio-q <audio-or-video> "<question>" tag=usage-error' >&2
  exit 64
fi

if [[ ! -f "$INPUT" ]]; then
  echo "[audio-q] error: file not found: $INPUT tag=usage-error" >&2
  exit 64
fi

# Audio scene Q&A requires a multimodal LLM; no local open-source
# equivalent ships at the quality bar today. If the user explicitly
# requested local mode, fail loud — silently falling back to an API
# call would ship audio over the wire without consent.
if [[ "${_WATCH_AUDIO_MODE_RAW:-}" == "local" ]]; then
  cat >&2 <<'ERR'
[audio-q] error: audio-q has no local backend tag=audio-q-requires-api
Audio scene Q&A requires a hosted model. Either:
  - unset WATCH_AUDIO_MODE to use the configured API path, or
  - export WATCH_AUDIO_MODE=kyma (or byok) for this call.
ERR
  exit 2
fi

if ! watch_cli_audio_mode_check "understand"; then
  echo "[audio-q] error: no usable audio backend tag=transcribe-other" >&2
  exit 4
fi

for dep in ffmpeg ffprobe jq curl base64; do
  if ! command -v "$dep" >/dev/null 2>&1; then
    echo "[audio-q] error: $dep not found on PATH tag=missing-dep:$dep" >&2
    exit 2
  fi
done

HASH="$(echo -n "$INPUT" | shasum | cut -c1-10)"
AUDIO="/tmp/audioq_${HASH}.mp3"
if [[ ! -s "$AUDIO" ]]; then
  if ! ffmpeg -hide_banner -loglevel error -y -i "$INPUT" \
    -vn -ac 1 -ar 16000 -b:a 48k -f mp3 "$AUDIO" >&2 2>&1; then
    echo "[audio-q] error: ffmpeg audio extraction failed tag=transcribe-other" >&2
    exit 4
  fi
fi

# POSIX size check: wc -c works on both macOS and Linux without a flag.
SIZE="$(wc -c < "$AUDIO" | tr -d ' ')"
if (( SIZE > 19 * 1024 * 1024 )); then
  echo "[audio-q] error: audio is $((SIZE / 1024 / 1024))MB — exceeds 20MB inline cap. Trim source first. tag=transcribe-other" >&2
  exit 4
fi

# Silence guard: multimodal LLMs hallucinate plausible-sounding scene
# descriptions on silent input rather than reporting "no audio". Skip
# the provider call so we never return fabricated tone/music/voice.
MAX_DB="$(ffmpeg -i "$AUDIO" -af volumedetect -f null /dev/null 2>&1 | \
          awk -F': ' '/max_volume/ { gsub(" dB", "", $2); print $2; exit }')"
if [[ -n "$MAX_DB" ]]; then
  IS_SILENT="$(awk -v v="$MAX_DB" 'BEGIN { print (v < -60.0) ? 1 : 0 }')"
  if [[ "$IS_SILENT" == "1" ]]; then
    echo "[audio-q] error: audio is silent (max_volume ${MAX_DB} dB) tag=transcribe-silent-audio" >&2
    exit 4
  fi
fi

# Audio duration for Kyma billing hint (rounded up to int seconds).
DUR_SEC=$(ffprobe -v error -show_entries format=duration \
            -of default=nw=1:nk=1 "$AUDIO" 2>/dev/null | awk '{ printf "%d", ($1 + 1) }')

case "$WATCH_AUDIO_MODE" in
  kyma)
    # Resolve model: --model flag > WATCH_AUDIO_MODEL env > default alias
    AUDIO_MODEL="${MODEL:-${WATCH_AUDIO_MODEL:-audio-understand}}"
    
    # Use the "audio-understand" alias rather than a concrete SKU.
    # Kyma can swap the underlying model without breaking watch-cli.
    BODY="$(curl -sS -X POST \
      -w "%{http_code}" \
      -o /dev/stdout \
      --max-time 300 \
      -H "Authorization: Bearer $KYMA_API_KEY" \
      -H "User-Agent: $WATCH_CLI_USER_AGENT" \
      -F "file=@$AUDIO;type=audio/mpeg" \
      -F "model=$AUDIO_MODEL" \
      -F "question=$QUESTION" \
      -F "duration_sec=$DUR_SEC" \
      "$WATCH_KYMA_BASE/v1/audio/understand" 2>/dev/null)" || {
      echo "[audio-q] error: Kyma request failed tag=transcribe-other" >&2
      exit 4
    }
    HTTP_CODE="${BODY: -3}"
    RESP="${BODY:0:${#BODY}-3}"
    case "$HTTP_CODE" in
      200)
        TEXT="$(echo "$RESP" | jq -r '.answer // empty')"
        if [[ -z "$TEXT" ]]; then
          ERR="$(echo "$RESP" | jq -r '.error.message // "unknown error"')"
          echo "[audio-q] error: Kyma call returned empty answer: $ERR tag=transcribe-other" >&2
          exit 4
        fi
        echo "$TEXT"
        ;;
      402|429)
        echo "[audio-q] error: Kyma quota or rate limit (HTTP $HTTP_CODE) tag=transcribe-quota" >&2
        exit 4 ;;
      408|504)
        echo "[audio-q] error: Kyma timeout (HTTP $HTTP_CODE) tag=transcribe-timeout" >&2
        exit 4 ;;
      *)
        echo "[audio-q] error: Kyma returned HTTP $HTTP_CODE tag=transcribe-other" >&2
        exit 4 ;;
    esac
    ;;

  direct)
    # Resolve model: --model flag > WATCH_AUDIO_MODEL env > default
    AUDIO_MODEL="${MODEL:-${WATCH_AUDIO_MODEL:-gemini-2.5-flash}}"
    
    B64="$(base64 < "$AUDIO" | tr -d '\n')"
    REQ_BODY="$(jq -n \
      --arg q "$QUESTION" \
      --arg data "$B64" \
      --arg model "$AUDIO_MODEL" \
      '{
        model: $model,
        contents: [{
          parts: [
            { inline_data: { mime_type: "audio/mp3", data: $data } },
            { text: $q }
          ]
        }],
        generationConfig: { temperature: 0.3, maxOutputTokens: 2048 }
      }')"

    BODY="$(curl -sS -X POST \
      -w "%{http_code}" \
      -o /dev/stdout \
      --max-time 300 \
      -H "Content-Type: application/json" \
      -H "x-goog-api-key: $GOOGLE_AI_KEY" \
      -H "User-Agent: $WATCH_CLI_USER_AGENT" \
      -d "$REQ_BODY" \
      "https://generativelanguage.googleapis.com/v1beta/models/${AUDIO_MODEL}:generateContent" 2>/dev/null)" || {
      echo "[audio-q] error: Gemini request failed tag=transcribe-other" >&2
      exit 4
    }
    HTTP_CODE="${BODY: -3}"
    RESP="${BODY:0:${#BODY}-3}"
    case "$HTTP_CODE" in
      200)
        TEXT="$(echo "$RESP" | jq -r '.candidates[0].content.parts[0].text // empty')"
        if [[ -z "$TEXT" ]]; then
          ERR="$(echo "$RESP" | jq -r '.error.message // "unknown error"')"
          echo "[audio-q] error: Gemini call returned empty answer: $ERR tag=transcribe-other" >&2
          exit 4
        fi
        echo "$TEXT"
        ;;
      402|429)
        echo "[audio-q] error: Gemini quota or rate limit (HTTP $HTTP_CODE) tag=transcribe-quota" >&2
        exit 4 ;;
      408|504)
        echo "[audio-q] error: Gemini timeout (HTTP $HTTP_CODE) tag=transcribe-timeout" >&2
        exit 4 ;;
      *)
        echo "[audio-q] error: Gemini returned HTTP $HTTP_CODE tag=transcribe-other" >&2
        exit 4 ;;
    esac
    ;;
esac
