#!/usr/bin/env bash
# dl-video <url> [out-dir]
# Downloads a video from any yt-dlp-supported platform (YouTube, X,
# LinkedIn, TikTok, Reddit, Vimeo, Facebook, …) into a local mp4 and
# prints the absolute path on stdout. Stderr carries progress.
#
# Cookie fallback (4 tiers, tried in order):
#   1. Anonymous fetch — works for all public videos.
#   2. Auto-detect signed-in browser (Chrome → Firefox → Safari → Edge).
#      Override via WATCH_BROWSER=chrome|firefox|safari|edge|brave|chromium.
#   3. Manual cookies file via --cookies <file> (Netscape format).
#   4. Graceful error with guidance — no silent failure.
#
# Exit codes (see docs/exit-codes.md):
#   0 success · 2 missing-dep · 3 download fail · 64 usage error · 1 other

set -uo pipefail

URL=""
OUTDIR="/tmp/dl-video"
COOKIES_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --cookies)
      COOKIES_FILE="$2"
      shift 2
      ;;
    --cookies=*)
      COOKIES_FILE="${1#*=}"
      shift
      ;;
    -h|--help)
      sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -V|--version)
      echo "watch-cli v0.2.0"
      exit 0
      ;;
    *)
      if [[ -z "$URL" ]]; then
        URL="$1"
      elif [[ "$OUTDIR" == "/tmp/dl-video" ]]; then
        OUTDIR="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$URL" ]]; then
  echo "usage: dl-video <url> [out-dir] [--cookies <file>] tag=usage-error" >&2
  exit 64
fi

if ! command -v yt-dlp >/dev/null 2>&1; then
  echo "[dl-video] error: yt-dlp not found on PATH. Install via 'brew install yt-dlp' or 'pipx install yt-dlp'. tag=missing-dep:yt-dlp" >&2
  exit 2
fi

mkdir -p "$OUTDIR"

# Idempotent cache: same URL → same output file.
HASH="$(echo -n "$URL" | shasum | cut -c1-12)"
OUT="$OUTDIR/$HASH.mp4"
if [[ -s "$OUT" ]]; then
  echo "$OUT"
  exit 0
fi

# ≤720p single-file format keeps downloads quick and avoids the bv*+ba
# merge path which fails on hosts (LinkedIn, FB) that only expose one
# muxed file. /best fallback covers everything else.
FORMAT='best[height<=720]/best'

run_dl() {
  yt-dlp \
    --no-playlist \
    --no-warnings \
    --no-progress \
    --merge-output-format mp4 \
    -f "$FORMAT" \
    -o "$OUT" \
    "$@" \
    "$URL" >&2
}

# Classify yt-dlp's last stderr log into one of the documented tags.
# Falls through to download-other when nothing matches.
classify_failure() {
  local log="/tmp/dl-video.last.log"
  [[ -f "$log" ]] || { echo "download-other"; return; }
  local body
  body="$(tr '[:upper:]' '[:lower:]' < "$log")"
  if grep -qE 'sign in|login required|authentication|private|members[- ]only|http error 401|http error 403' <<< "$body"; then
    echo "download-auth"
  elif grep -qE 'geo[- ]restrict|not available in your country|region' <<< "$body"; then
    echo "download-region"
  elif grep -qE 'timed out|timeout|connection reset|temporary failure|network is unreachable|name or service not known|getaddrinfo|tls handshake' <<< "$body"; then
    echo "download-network"
  else
    echo "download-other"
  fi
}

# Tier 1: anonymous. Public videos succeed here.
if run_dl 2>/tmp/dl-video.last.log; then
  if [[ -s "$OUT" ]]; then
    echo "$OUT"
    exit 0
  fi
fi

# Tier 3: caller passed --cookies file. Skip browser autodetect.
if [[ -n "$COOKIES_FILE" ]]; then
  echo "[dl-video] anonymous fetch failed, retrying with $COOKIES_FILE…" >&2
  if [[ ! -f "$COOKIES_FILE" ]]; then
    echo "[dl-video] error: cookies file not found: $COOKIES_FILE tag=usage-error" >&2
    exit 64
  fi
  if run_dl --cookies "$COOKIES_FILE" 2>/tmp/dl-video.last.log; then
    if [[ -s "$OUT" ]]; then
      echo "$OUT"
      exit 0
    fi
  fi
  TAG="$(classify_failure)"
  echo "[dl-video] error: download failed for $URL even with provided cookies tag=$TAG" >&2
  exit 3
fi

# Tier 2: auto-detect signed-in browser.
# Order: Chrome → Firefox → Safari → Edge → Brave → Chromium.
# Override via env: WATCH_BROWSER=firefox.
declare -a BROWSERS
if [[ -n "${WATCH_BROWSER:-}" ]]; then
  BROWSERS=("$WATCH_BROWSER")
else
  BROWSERS=(chrome firefox safari edge brave chromium)
fi

for BROWSER in "${BROWSERS[@]}"; do
  echo "[dl-video] anonymous fetch failed, retrying with $BROWSER cookies…" >&2
  if run_dl --cookies-from-browser "$BROWSER" 2>/tmp/dl-video.last.log; then
    if [[ -s "$OUT" ]]; then
      echo "$OUT"
      exit 0
    fi
  fi
done

# Tier 4: classify the final failure and emit a tag-tagged stderr line.
TAG="$(classify_failure)"
case "$TAG" in
  download-auth)
    cat >&2 <<ERR
[dl-video] error: download failed for $URL tag=download-auth — sign in to the platform in your browser and re-run, or pass --cookies <file>

Three ways to fix:
  1. Sign in to the platform in Chrome (or Firefox/Safari/Edge), then re-run.
     watch-cli auto-reads cookies from any signed-in browser.

  2. Export cookies.txt (Netscape format) and pass:
       watch-cli <url> --cookies ~/path/to/cookies.txt
     See https://github.com/sonpiaz/watch-cli/blob/main/docs/cookies.md

  3. Try a public URL — most YouTube, TikTok, and Reddit videos
     work without cookies.
ERR
    ;;
  download-region)
    echo "[dl-video] error: download failed for $URL tag=download-region — video is geo-restricted, try a VPN in the supported region" >&2
    ;;
  download-network)
    echo "[dl-video] error: download failed for $URL tag=download-network — transient network failure, wait and retry" >&2
    ;;
  *)
    echo "[dl-video] error: download failed for $URL tag=download-other — surface yt-dlp stderr above for details" >&2
    ;;
esac
exit 3
